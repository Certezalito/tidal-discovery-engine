# Core API credentials
LASTFM_API_KEY=your_lastfm_api_key
GEMINI_API_KEY=your_gemini_api_key

# Optional Gemini model configuration
# Precedence for GEMINI_MODEL resolution: exported env var > .env value > built-in default
GEMINI_MODEL=

# Optional fallback model used only when primary model is unavailable/not found
GEMINI_FALLBACK_MODEL=
